# Copy this file to `.env.local` and fill in the values for your environment.

# Base URL of the REST backend API (no trailing slash).
# Leave this EMPTY (or omit the file) to run the app fully client-side with
# data persisted in the browser's localStorage.
#
# Example for the local .NET API described in docs/BACKEND.md:
# VITE_API_BASE_URL=https://localhost:7042/api
VITE_API_BASE_URL=
